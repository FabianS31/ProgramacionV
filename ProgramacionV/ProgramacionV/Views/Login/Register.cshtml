@model ProgramacionV.Models.RegisterViewModel

@{
    Layout = null;
    ViewData["Title"] = "Crear Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Rincón Psi - Crear Usuario</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

            :root {
                --azul-principal: #003A8C;
                --azul-secundario: #0A4FAF;
                --fondo: #F5F8FC;
            }

            body {
                background: var(--fondo);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                font-family: 'Segoe UI',sans-serif;
            }

            .registro-card {
                width: 500px;
                background: white;
                padding: 40px;
                border-radius: 18px;
                box-shadow: 0 8px 25px rgba(0,0,0,.10);
            }

            h1 {
                text-align: center;
                color: var(--azul-principal);
                margin-bottom: 10px;
                font-weight: bold;
            }

            .subtitulo {
                text-align: center;
                color: #666;
                margin-bottom: 30px;
            }

            .btn-rinconpsi {
                width: 100%;
                background: var(--azul-principal);
                color: white;
                font-weight: bold;
                border: none;
                padding: 12px;
                border-radius: 8px;
                transition: .3s;
            }

                .btn-rinconpsi:hover {
                    background: var(--azul-secundario);
                    color: white;
                }

            .volver {
                text-align: center;
                margin-top: 20px;
            }

                .volver a {
                    color: var(--azul-principal);
                    text-decoration: none;
                    font-weight: bold;
                }

                    .volver a:hover {
                        text-decoration: underline;
                    }

    </style>

</head>

<body>

    <div class="registro-card">

        <h1>Rincón Psi</h1>

        <div class="subtitulo">
            Crear Nuevo Usuario
        </div>

        <form asp-action="Register"
              asp-controller="Login"
              method="post">

            <div class="mb-3">

                <label class="form-label">
                    Usuario
                </label>

                <input asp-for="Username"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Correo Electrónico
                </label>

                <input asp-for="Email"
                       type="email"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Contraseña
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control" />

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Confirmar Contraseña
                </label>

                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control" />

            </div>

            <button type="submit"
                    class="btn-rinconpsi">

                Crear Usuario

            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Error
            </div>
        }

        <div class="volver">

            <a asp-controller="Login"
                   asp-action="Index">

                Volver al Login

            </a>

        </div>

    </div>

</body>
</html>