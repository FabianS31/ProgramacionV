@{
    ViewData["Title"] = "Inicio";
}

<div class="row" style="margin: 0; padding: 20px;">

    <div class="col-md-3">
        <div class="card-eduges" style="min-height: 80vh; align-items: stretch; justify-content: flex-start; padding: 25px;">
            <h3 style="font-size: 22px; text-align: center; margin-bottom: 20px; color: var(--azul-principal);">Menú Diario</h3>

            <div style="margin-bottom: 20px; color: var(--texto);">
                <p><strong>Hoy:</strong> @DateTime.Now.ToString("dd/MM/yyyy")</p>
                <hr />
                <p>Actividades programadas...</p>
            </div>

            <a asp-controller="Calendario" asp-action="Index" class="btn-eduges" style="margin-top: auto;">Calendario</a>
        </div>
    </div>

    <div class="col-md-9">
        <section class="hero" style="padding-top: 0; text-align: left;">
            <h2>Rincón Psi</h2>
            <p>Administre pacientes y profesionales desde una única plataforma.</p>
        </section>

        <section class="contenedor-cards" style="display: flex; flex-direction: row; justify-content: center; gap: 20px; flex-wrap: wrap; margin-top: 20px;">

            <div class="card-eduges" style="flex: 1 1 300px; max-width: 400px; min-height: 200px; align-items: center; justify-content: space-between;">
                <h3>PACIENTES</h3>
                <div class="numero" style="font-size: 32px; font-weight: bold; color: var(--azul-principal);">@ViewBag.TotalAlumnos</div>
                <a asp-controller="Alumnos" asp-action="Create" class="btn-eduges"> Gestionar Pacientes</a>
            </div>

            <div class="card-eduges" style="flex: 1 1 300px; max-width: 400px; min-height: 200px; align-items: center; justify-content: space-between;">
                <h3>PROFESIONALES</h3>
                <div class="numero" style="font-size: 32px; font-weight: bold; color: var(--azul-principal);">@ViewBag.TotalProfesionales</div>
                <a href="#" class="btn-eduges"> Gestionar Profesionales</a>
            </div>

        </section>
    </div>
</div>