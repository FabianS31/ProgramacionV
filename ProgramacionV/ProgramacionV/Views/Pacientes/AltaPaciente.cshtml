@model ProgramacionV.Models.AlumnoViewModel

<section class="hero">
    <h2>Alta de Paciente</h2>
</section>

<div class="container" style="max-width: 600px;">
    <div class="card-eduges">
        <h3 style="color: var(--azul-principal); margin-bottom: 20px; text-align: center;">Datos del Paciente</h3>

        <form asp-controller="Alumnos" asp-action="Create" method="post">
            <div class="mb-3">
                <input type="text" name="Nombre" placeholder="Nombre" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" required />
            </div>
            <div class="mb-3">
                <input type="text" name="Apellido" placeholder="Apellido" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" required />
            </div>
            <div class="mb-3">
                <input type="text" name="Dni" placeholder="DNI" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" required />
            </div>

            <div class="mb-4 d-flex gap-2">
                <select name="TutorId" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto); flex-grow: 1;">
                    <option value="">Seleccione un tutor...</option>
                </select>
                <button type="button" class="btn-eduges" style="width: 60px;" data-bs-toggle="modal" data-bs-target="#tutorModal">+</button>
            </div>

            <button type="submit" class="btn-eduges">Guardar Paciente</button>
        </form>
    </div>
</div>

<div class="modal fade" id="tutorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="padding: 20px; border-radius: 15px;">
            <h4 style="color: var(--azul-principal); text-align: center;">Nuevo Tutor</h4>
            <div class="mb-2">
                <input type="text" id="tutorNombre" placeholder="Nombre" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" />
            </div>
            <div class="mb-2">
                <input type="text" id="tutorApellido" placeholder="Apellido" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" />
            </div>
            <div class="mb-3">
                <input type="text" id="tutorDni" placeholder="DNI" class="btn-eduges" style="background: white; border: 1px solid #ccc; color: var(--texto);" />
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn-eduges" style="background: #666;" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-eduges" onclick="guardarTutor()">Guardar Tutor</button>
            </div>
        </div>
    </div>
</div>